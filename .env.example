# Next.js reads NEXT_PUBLIC_* variables. (If you have VITE_* names from another
# tool, they map 1:1 — VITE_SUPABASE_URL -> NEXT_PUBLIC_SUPABASE_URL, etc.)
#
# These are optional: the app ships with a safe publishable-key default baked in
# and falls back to localStorage if Supabase is unreachable. Set them to point
# at your own Supabase project. See SUPABASE.md.
NEXT_PUBLIC_SUPABASE_URL=https://kresglhdqefvprebmhsw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
